# .gitignore
#
# This file is part of commitizen-spdx-changelog, a plugin
# for commitizen that generates changelogs in SPDX format.

# Python-generated files
*.egg-info
*.py[oc]
__pycache__/
build/
dist/
wheels/

# Environment variables
.env

# Virtual environments
.venv

# Temporary files
tmp/

# Documentation
site/